rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users Collection
    match /users/{userId} {
      // Anyone can read user data (needed for certificate verification to show company name)
      allow read: if true;
      // Only the user themselves can create or update their own document
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Certificates Collection
    match /certificates/{certId} {
      // Anyone can read certificates for public verification
      allow read: if true;
      // Only authenticated users can create certificates, and the uid must match their own
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      // Only the owner (or an admin) can update/delete their certificates
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
    
    // Allow admins full access (optional, if you maintain an admin role logic)
    // match /{document=**} {
    //   allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    // }
  }
}
